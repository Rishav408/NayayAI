# Google Gemini API Configuration
GEMINI_API_KEY="Paste Here"

# Flask Configuration
SECRET_KEY=your_secret_key_for_production
DEBUG=false
PORT=5000

# LangChain Configuration (Optional)
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langchain_api_key_optional
LANGCHAIN_PROJECT=nayay-backend

# Gemini Model Configuration
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TEMPERATURE=0.7
GEMINI_MAX_TOKENS=8192

# Search Configuration
SEARCH_MAX_RESULTS=5
SEARCH_TIMEOUT=30

# Memory Configuration
CONVERSATION_MEMORY_SIZE=10

# Instructions:
# 1. Copy this file to .env
# 2. Replace the placeholder values with your actual API keys
# 3. Never commit the .env file to version control
# 4. Get your Gemini API key from: https://makersuite.google.com/app/apikey
